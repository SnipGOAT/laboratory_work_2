<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="ETL_Process_Clean" name="ETL: сбор и объединение данных" isExecutable="true">
    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_1" name="Начало ETL">
      <bpmn:outgoing>Flow_to_ParallelGateway</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- Параллельный шлюз (разветвление) -->
    <bpmn:parallelGateway id="ParallelGateway_1" name="Разветвление">
      <bpmn:incoming>Flow_to_ParallelGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Extract1</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_Extract2</bpmn:outgoing>
    </bpmn:parallelGateway>
    
    <!-- Извлечение из source1 -->
    <bpmn:serviceTask id="ExtractSource1" name="Извлечь данные из source1.db">
      <bpmn:incoming>Flow_to_Extract1</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Extract1</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Извлечение из source2 -->
    <bpmn:serviceTask id="ExtractSource2" name="Извлечь данные из source2.db">
      <bpmn:incoming>Flow_to_Extract2</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Extract2</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Подпроцесс нормализации для source1 -->
    <bpmn:subProcess id="SubProcess_Norm1" name="Нормализация ФИО (source1)">
      <bpmn:incoming>Flow_from_Extract1</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Norm1</bpmn:outgoing>
      <bpmn:startEvent id="SubStart1" />
      <bpmn:scriptTask id="CleanTask1" name="Очистка и нижний регистр">
        <bpmn:incoming>Flow_Sub1_1</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub1_2</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="TokenizeTask1" name="Разбивка на токены">
        <bpmn:incoming>Flow_Sub1_2</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub1_3</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="SynonymTask1" name="Замена инициалов и синонимов">
        <bpmn:incoming>Flow_Sub1_3</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub1_4</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="SortTask1" name="Сортировка и склейка">
        <bpmn:incoming>Flow_Sub1_4</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub1_5</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:endEvent id="SubEnd1" />
      <bpmn:sequenceFlow id="Flow_Sub1_1" sourceRef="SubStart1" targetRef="CleanTask1" />
      <bpmn:sequenceFlow id="Flow_Sub1_2" sourceRef="CleanTask1" targetRef="TokenizeTask1" />
      <bpmn:sequenceFlow id="Flow_Sub1_3" sourceRef="TokenizeTask1" targetRef="SynonymTask1" />
      <bpmn:sequenceFlow id="Flow_Sub1_4" sourceRef="SynonymTask1" targetRef="SortTask1" />
      <bpmn:sequenceFlow id="Flow_Sub1_5" sourceRef="SortTask1" targetRef="SubEnd1" />
    </bpmn:subProcess>
    
    <!-- Подпроцесс нормализации для source2 -->
    <bpmn:subProcess id="SubProcess_Norm2" name="Нормализация ФИО (source2)">
      <bpmn:incoming>Flow_from_Extract2</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Norm2</bpmn:outgoing>
      <bpmn:startEvent id="SubStart2" />
      <bpmn:scriptTask id="CleanTask2" name="Очистка и нижний регистр">
        <bpmn:incoming>Flow_Sub2_1</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub2_2</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="TokenizeTask2" name="Разбивка на токены">
        <bpmn:incoming>Flow_Sub2_2</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub2_3</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="SynonymTask2" name="Замена инициалов и синонимов">
        <bpmn:incoming>Flow_Sub2_3</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub2_4</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="SortTask2" name="Сортировка и склейка">
        <bpmn:incoming>Flow_Sub2_4</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub2_5</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:endEvent id="SubEnd2" />
      <bpmn:sequenceFlow id="Flow_Sub2_1" sourceRef="SubStart2" targetRef="CleanTask2" />
      <bpmn:sequenceFlow id="Flow_Sub2_2" sourceRef="CleanTask2" targetRef="TokenizeTask2" />
      <bpmn:sequenceFlow id="Flow_Sub2_3" sourceRef="TokenizeTask2" targetRef="SynonymTask2" />
      <bpmn:sequenceFlow id="Flow_Sub2_4" sourceRef="SynonymTask2" targetRef="SortTask2" />
      <bpmn:sequenceFlow id="Flow_Sub2_5" sourceRef="SortTask2" targetRef="SubEnd2" />
    </bpmn:subProcess>
    
    <!-- Сведение параллельных веток -->
    <bpmn:parallelGateway id="ParallelGateway_2" name="Сведение">
      <bpmn:incoming>Flow_from_Norm1</bpmn:incoming>
      <bpmn:incoming>Flow_from_Norm2</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Merge</bpmn:outgoing>
    </bpmn:parallelGateway>
    
    <!-- Объединение данных -->
    <bpmn:serviceTask id="MergeTask" name="Объединить данные в словарь по нормализованному ключу">
      <bpmn:incoming>Flow_to_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Load</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Загрузка в ХД -->
    <bpmn:serviceTask id="LoadTask" name="Загрузить объединённые записи в ХД">
      <bpmn:incoming>Flow_to_Load</bpmn:incoming>
      <bpmn:outgoing>Flow_to_End</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- End Event -->
    <bpmn:endEvent id="EndEvent_1" name="Конец ETL">
      <bpmn:incoming>Flow_to_End</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- Sequence Flows верхнего уровня -->
    <bpmn:sequenceFlow id="Flow_to_ParallelGateway" sourceRef="StartEvent_1" targetRef="ParallelGateway_1" />
    <bpmn:sequenceFlow id="Flow_to_Extract1" sourceRef="ParallelGateway_1" targetRef="ExtractSource1" />
    <bpmn:sequenceFlow id="Flow_to_Extract2" sourceRef="ParallelGateway_1" targetRef="ExtractSource2" />
    <bpmn:sequenceFlow id="Flow_from_Extract1" sourceRef="ExtractSource1" targetRef="SubProcess_Norm1" />
    <bpmn:sequenceFlow id="Flow_from_Extract2" sourceRef="ExtractSource2" targetRef="SubProcess_Norm2" />
    <bpmn:sequenceFlow id="Flow_from_Norm1" sourceRef="SubProcess_Norm1" targetRef="ParallelGateway_2" />
    <bpmn:sequenceFlow id="Flow_from_Norm2" sourceRef="SubProcess_Norm2" targetRef="ParallelGateway_2" />
    <bpmn:sequenceFlow id="Flow_to_Merge" sourceRef="ParallelGateway_2" targetRef="MergeTask" />
    <bpmn:sequenceFlow id="Flow_to_Load" sourceRef="MergeTask" targetRef="LoadTask" />
    <bpmn:sequenceFlow id="Flow_to_End" sourceRef="LoadTask" targetRef="EndEvent_1" />
  </bpmn:process>
  
  <!-- BPMN Diagram (графическое расположение) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ETL_Process_Clean">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ParallelGateway_1_di" bpmnElement="ParallelGateway_1">
        <dc:Bounds x="160" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractSource1_di" bpmnElement="ExtractSource1">
        <dc:Bounds x="260" y="80" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractSource2_di" bpmnElement="ExtractSource2">
        <dc:Bounds x="260" y="260" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_Norm1_di" bpmnElement="SubProcess_Norm1" isExpanded="true">
        <dc:Bounds x="440" y="50" width="300" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_Norm2_di" bpmnElement="SubProcess_Norm2" isExpanded="true">
        <dc:Bounds x="440" y="230" width="300" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ParallelGateway_2_di" bpmnElement="ParallelGateway_2">
        <dc:Bounds x="800" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MergeTask_di" bpmnElement="MergeTask">
        <dc:Bounds x="910" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LoadTask_di" bpmnElement="LoadTask">
        <dc:Bounds x="1080" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1250" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <!-- Edges -->
      <bpmndi:BPMNEdge id="Edge1" bpmnElement="Flow_to_ParallelGateway">
        <di:waypoint x="116" y="198" />
        <di:waypoint x="160" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge2" bpmnElement="Flow_to_Extract1">
        <di:waypoint x="185" y="175" />
        <di:waypoint x="185" y="110" />
        <di:waypoint x="260" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge3" bpmnElement="Flow_to_Extract2">
        <di:waypoint x="185" y="225" />
        <di:waypoint x="185" y="290" />
        <di:waypoint x="260" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge4" bpmnElement="Flow_from_Extract1">
        <di:waypoint x="380" y="110" />
        <di:waypoint x="440" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge5" bpmnElement="Flow_from_Extract2">
        <di:waypoint x="380" y="290" />
        <di:waypoint x="440" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge6" bpmnElement="Flow_from_Norm1">
        <di:waypoint x="740" y="110" />
        <di:waypoint x="800" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge7" bpmnElement="Flow_from_Norm2">
        <di:waypoint x="740" y="290" />
        <di:waypoint x="800" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge8" bpmnElement="Flow_to_Merge">
        <di:waypoint x="850" y="200" />
        <di:waypoint x="910" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge9" bpmnElement="Flow_to_Load">
        <di:waypoint x="1030" y="190" />
        <di:waypoint x="1080" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge10" bpmnElement="Flow_to_End">
        <di:waypoint x="1200" y="190" />
        <di:waypoint x="1250" y="198" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
