@startuml
!define table class

title "ER-диаграмма – нормализованные источники и денормализованное ХД"

table "source1.projects" {
    * id : INTEGER <<PK>>
    --
    full_name : TEXT
    role : TEXT
    project_name : TEXT
    tech_stack : TEXT
}

table "source2.resumes" {
    * id : INTEGER <<PK>>
    --
    full_name : TEXT
    competencies : TEXT
    salary : REAL
    bonus : REAL
}

table "dw.unified_employee" {
    * id : INTEGER <<PK>>
    --
    normalized_key : TEXT <<UK>>
    original_name_src1 : TEXT
    original_name_src2 : TEXT
    role : TEXT
    project_name : TEXT
    tech_stack : TEXT
    competencies : TEXT
    salary : REAL
    bonus : REAL
}

table "dw.normalization_rules" {
    * rule_id : INTEGER <<PK>>
    --
    original_form : TEXT
    canonical_form : TEXT
    rule_type : TEXT   -- 'synonym', 'initials', 'abbr'
}

note right of dw.normalization_rules
  Примеры правил:
  ('георгий','егор','synonym')
  ('с.с.','сергей сергеевич','initials')
  ('а.а.','алексей алексеевич','initials')
end note

@enduml
